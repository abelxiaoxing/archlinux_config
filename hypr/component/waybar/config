{
	"layer": "bottom",
    "position": "top",
	"modules-left": ["custom/launcher","cpu","memory","network","custom/media","tray","wlr/workspaces"],
	"modules-center": ["wlr/taskbar"],
	"modules-right": ["custom/updates","custom/wallpaper","backlight","pulseaudio","clock", "battery","custom/power"],
	
	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 1,
		"format": "{icon} {volume}%",
		"format-muted": "{icon} {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["", "", ""]
		}
	},
	"wlr/taskbar":{
		"format": "{icon}",
		"all-outputs":false,
		"active-first":false,
		"icon-size":24,
		"icon-theme":"Zafiro",
		"tooltip-format":"{title}",
		"on-click":"minimize-raise",
		"on-click-middle":"close",
		"on-click-right":"maximize",
		"on-update":""
	},

	"network": {
		"tooltip": true,
		"format-wifi": "  {essid}",
    "on-click": "bash ~/.config/system_scripts/rofi-wifi-menu.sh",
		"format-ethernet": ""
	},
	"backlight": {
		"tooltip": false,
		"format": " {}%",
		"interval":1,
        "on-scroll-up": "xbacklight -inc 1",
		"on-scroll-down": "xbacklight -dec 1"
	},
    "wlr/workspaces": {
        "format": "{icon}",
        "format-active": " {icon} ",
        "on-click": "activate"
        // "format-icons":{
        //     "10":"10"
        // }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["", "", "", "", ""]
    },
	"tray":{
		"icon-size":18,
		"spacing": 10
	},
    "clock": {
        "format": "{: %I:%M %p   %d/%m/%Y}"
    },
    "cpu": {
        "interval": 15,
        "format": " {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": " {}%",
        "max-length": 10
    },
    "custom/media": {
        "interval": 30,
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 20,
        "format-icons": {
            "spotify": " ",
            "default": " "
        },
        "escape": true,
        "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": " ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi"
    },
    "custom/power":{
        "format": " ",
        "on-click": "bash ~/.config/rofi/leave/leave.sh",
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "~/.config/system_scripts/checkupdates | wc -l",
        "exec-if": "[[ $(~/.config/system_scripts/checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "alacritty -e paru -Syu && notify-send 'The system has been updated' "
    },
    "custom/wallpaper":{
        "format":" ",
        /* "on-click": "bash ~/.config/system_scripts/pkill_bc" */
        "on-click": "~/.config/hypr/scripts/tools/expand cycle"
    }
}
